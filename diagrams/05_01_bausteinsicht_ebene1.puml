@startuml
skinparam componentStyle uml2
skinparam component {
  BackgroundColor<<Simulator>> LightBlue
  BackgroundColor<<External>> White
  BorderColor<<Simulator>> DarkBlue
}

' Hauptkomponente: Simulator
package "Simulator" <<Simulator>> {
  component "simulator-gui" as SimGUI #LightCyan
  component "puzzleSolver\nZolver" as PuzzleSolver #LightGray
  component "solver-v2" as SolverV2 #LightGreen
}

' Externe Abhängigkeiten
database "Dateisystem" as FS <<External>>

' Schnittstellen
SimGUI --> SolverV2
SimGUI --> PuzzleSolver
SolverV2 --> FS
PuzzleSolver --> FS
FS --> SimGUI : Bilder werden in GUI geholt
@enduml