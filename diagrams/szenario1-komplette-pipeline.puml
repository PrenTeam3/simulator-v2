@startuml
title Szenario 1: Komplette Pipeline über GUI (Solver V2 mit Edge Solver V2)

skinparam ParticipantPadding 60
skinparam BoxPadding 20
hide footbox

actor User
participant Simulator
participant PipelineWorker
participant Analyzer
participant Solver
participant Assembly

User -> Simulator: 1. Start GUI
User -> Simulator: 2. Select image
User -> Simulator: 3. Select "Solver V2"
User -> Simulator: 4. Click "Run"

Simulator -> PipelineWorker: 5. start()
activate PipelineWorker

PipelineWorker -> Analyzer: 6. run_analysis(image_path)
activate Analyzer

Analyzer -> Analyzer: 7. detect_pieces()
Analyzer -> Analyzer: 8. analyze_piece_corners()
Analyzer -> Analyzer: 9. create_smoothed_svg()

Analyzer --> PipelineWorker: 10. temp_folder, analysis_data
deactivate Analyzer

PipelineWorker -> Simulator: 11. step_finished("Analysis")
Simulator -> User: 12. Update UI (Step 1)

PipelineWorker -> Solver: 13. solve_puzzle(temp_folder, "edge_v2")
activate Solver

Solver -> Solver: 14. prepare_puzzle_data()
Solver -> Solver: 15. solve_with_edges()

Solver -> Assembly: 16. EdgeSolverResults
activate Assembly

Assembly -> Assembly: 17. assemble_puzzle()

Assembly --> Solver: 18. assembly_results
deactivate Assembly

Solver --> PipelineWorker: 19. results
deactivate Solver

PipelineWorker -> Simulator: 20. pipeline_finished
deactivate PipelineWorker

Simulator -> User: 21. Show results\n(all 4 steps)

@enduml
