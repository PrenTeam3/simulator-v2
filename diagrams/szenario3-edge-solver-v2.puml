@startuml
title Szenario 3: Segment-Matching und Verbindungsauswahl

skinparam ParticipantPadding 80
skinparam BoxPadding 20
hide footbox

participant "EdgeSolverV2" as ES
participant "MatchingEngine" as ME
participant "SimilarityCalculator" as SC
participant "ConnectionSelector" as CS

ES -> ES: 1. solve_with_edges()

ES -> ES: 2. validate_frame_corners()

ES -> ES: 3. find_frame_segments()

ES -> ME: 4. match_all_piece_pairs()

ME -> SC: 5. for each piece pair (i, j):\nfor each segment pair

SC -> SC: 6. length_similarity()

SC -> SC: 7. shape_similarity() (ICP)

SC -> SC: 8. direction_compatibility()

SC -> SC: 9. composite_score =\n0.3*length + 0.5*shape + 0.2*direction

SC --> ME: 10. score

ME --> ES: 11. all_matches

ES -> CS: 12. determine_connections(all_matches)

CS -> CS: 13. for each piece:\nselect_top_2()

CS -> CS: 14. build_progressive_chains()

CS --> ES: 15. EdgeSolverResults (with chains)

ES -> ES: 16. visualize_connections()

@enduml
