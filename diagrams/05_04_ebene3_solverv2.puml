@startuml
title Component Diagram - Puzzle Solver V2 (Level 3)

' Style definitions matching your example
skinparam componentStyle uml2
skinparam component {
  BackgroundColor<<Manager>> LightCyan
  BackgroundColor<<Analyzer>> LightGreen
  BackgroundColor<<Solver>> LightYellow
  BackgroundColor<<Assembly>> LightPink

  BorderColor<<Manager>> DarkCyan
  BorderColor<<Analyzer>> DarkGreen
  BorderColor<<Solver>> Orange
  BorderColor<<Assembly>> Red
}

' 1. Main Manager (Top)
package "Solver Manager" <<Manager>> {
    component "Solver Manager\n[File: run.py / solve.py]" as MainManager
}

' 2. Analyzer Module (Below Manager)
package "Analyzer Module" <<Analyzer>> {
    component "PuzzleAnalyzer\n[File: core.py]" as AnalyzerCore
    component "SVGSmoother\n[File: svg_smoother.py]" as SVGSmoother
    component "SVGCornerDrawer\n[File: svg_corner_drawer.py]" as SVGCorner
    component "SVGVisualizer\n[File: svg_visualizer.py]" as SVGVis

    ' Force vertical stacking INSIDE the package to reduce width
    AnalyzerCore -[hidden]down-> SVGSmoother
    SVGSmoother -[hidden]down-> SVGCorner
    SVGCorner -[hidden]down-> SVGVis
}

' 3. Solver Module (Below Analyzer)
package "Solver Module (Edge V2)" <<Solver>> {
    component "EdgeSolver\n[File: edge_solver.py]" as EdgeSolver
    component "SegmentFinder\n[File: segment_finder.py]" as SegFinder
    component "ChainMatcher\n[File: chain_matcher.py]" as ChainMatch
    component "ConnectionSelector\n[File: connection_selector.py]" as ConnSelect
    component "EdgeSolverV2Visualizer\n[File: visualizer.py]" as SolverVis

    ' Force vertical stacking INSIDE the package to reduce width
    EdgeSolver -[hidden]down-> SegFinder
    SegFinder -[hidden]down-> ChainMatch
    ChainMatch -[hidden]down-> ConnSelect
    ConnSelect -[hidden]down-> SolverVis
}

' 4. Assembly Module (Below Solver)
package "Assembly Module" <<Assembly>> {
    component "AssemblySolver\n[File: assembly_solver.py]" as AssemSolver
    component "AssemblyVisualizer\n[File: assembly_visualizer.py]" as AssemVis

    ' Force vertical stacking INSIDE the package
    AssemSolver -[hidden]down-> AssemVis
}

' --- Main Vertical Flow (Package Stacking) ---
MainManager -down-> AnalyzerCore : Runs Analysis
AnalyzerCore -down-> EdgeSolver : Passes Data
EdgeSolver -down-> AssemSolver : Passes Matches

' --- Dependencies (Visual Links) ---
AnalyzerCore .down.> SVGSmoother
AnalyzerCore .down.> SVGCorner
AnalyzerCore .down.> SVGVis

EdgeSolver .down.> SegFinder
EdgeSolver .down.> ChainMatch
EdgeSolver .down.> ConnSelect
EdgeSolver .down.> SolverVis

AssemSolver .down.> AssemVis

@enduml