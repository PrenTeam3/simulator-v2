@startuml
title Container Diagram - Puzzle Solver V2 (Level 2)

' Style definitions matching your example file
skinparam componentStyle uml2
skinparam component {
  BackgroundColor<<Manager>> LightCyan
  BackgroundColor<<Analyzer>> LightGreen
  BackgroundColor<<Solver>> LightYellow
  BackgroundColor<<Assembly>> LightPink

  BorderColor<<Manager>> DarkCyan
  BorderColor<<Analyzer>> DarkGreen
  BorderColor<<Solver>> Orange
  BorderColor<<Assembly>> Red
}

package "Puzzle Solver V2 System" {

    ' 1. Solver Manager
    component "Solver Manager\n[File: run.py / solve.py]" as MainManager <<Manager>>

    ' 2. Analyzer Module
    component "Analyzer Module\n[Package: puzzle_analyzer]" as AnalyzerMod <<Analyzer>>

    ' 3. Solver Module
    component "Solver Module\n[Package: puzzle_solver]" as SolverMod <<Solver>>

    ' 4. Assembly Module
    component "Assembly Module\n[Package: assembly_solver]" as AssemblyMod <<Assembly>>

}

' --- Relationships ---

' Manager orchestrates the pipeline
MainManager -down-> AnalyzerMod : Runs Analysis
MainManager -down-> SolverMod : Runs Solving
MainManager -down-> AssemblyMod : Runs Assembly

' Data Flow between modules
SolverMod .up.> AnalyzerMod : Reads Analysis Data
AssemblyMod .up.> SolverMod : Reads Match Results

@enduml